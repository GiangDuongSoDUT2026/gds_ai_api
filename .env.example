# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gds_ai
POSTGRES_USER=gds_user
POSTGRES_PASSWORD=changeme

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=gds_user
RABBITMQ_PASSWORD=changeme
RABBITMQ_VHOST=gds_vhost
CELERY_BROKER_URL=amqp://gds_user:changeme@rabbitmq:5672/gds_vhost
CELERY_RESULT_BACKEND=rpc://

# ── Local Storage ─────────────────────────────────────────────────────────────
STORAGE_PATH=/data
STORAGE_BUCKET_VIDEOS=videos
STORAGE_BUCKET_FRAMES=frames
# Base URL used to build file links returned by the API
STORAGE_BASE_URL=http://localhost:8000/files

# ── GPU / Worker ──────────────────────────────────────────────────────────────
NUM_WORKERS=4
CUDA_VISIBLE_DEVICES=0,1  # A100: adjust as needed

# ── AI Models ────────────────────────────────────────────────────────────────
TRANSNETV2_WEIGHTS_DIR=/app/weights/transnetv2
WHISPER_MODEL=large-v3
CLIP_MODEL=ViT-L/14
TEXT_EMBED_MODEL=intfloat/multilingual-e5-large

# ── LLM (Chatbot) ────────────────────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | ollama | vllm
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# For local LLM on A100:
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://vllm:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=changeme-very-long-secret

# ── FalkorDB (Graph Database for GraphRAG) ───────────────────────────────────
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
FALKORDB_GRAPH_NAME=gds_knowledge
GRAPH_SYNC_INTERVAL_SECONDS=300

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development  # development | production
